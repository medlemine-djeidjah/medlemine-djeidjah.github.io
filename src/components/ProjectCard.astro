---
import type { Project } from '../i18n/content/projects';
import TechTag from './TechTag.astro';

interface Props {
  project: Project;
}

const { project } = Astro.props;
---

<div class="group bg-surface-raised border border-border hover:border-accent/30 transition-all duration-300 flex flex-col overflow-hidden">
  <!-- Content -->
  <div class="p-6 md:p-7 flex flex-col flex-1">
    <div class="flex items-start justify-between gap-3 mb-3">
      <h3 class="text-base font-display font-bold text-white uppercase tracking-tight group-hover:text-accent transition-colors">
        {project.title}
      </h3>
      <span class="text-xs font-mono text-neutral-600 flex-shrink-0 mt-0.5">{project.year}</span>
    </div>

    <p class="text-xs font-mono uppercase tracking-[0.15em] text-accent mb-3">{project.organization}</p>
    <p class="text-sm leading-relaxed text-neutral-500 mb-4">{project.description}</p>

    <!-- Metrics -->
    <div class="flex flex-wrap gap-2 mb-5">
      {project.metrics.map((m) => (
        <span class="text-xs font-semibold text-accent bg-accent/10 px-3 py-1.5 border border-accent/20">
          {m}
        </span>
      ))}
    </div>

    <!-- Highlights -->
    <ul class="space-y-2 mb-5">
      {
        project.highlights.map((h) => (
          <li class="flex gap-2.5 text-sm text-neutral-500 leading-relaxed">
            <span class="flex-shrink-0 mt-2 w-1 h-1 bg-accent" />
            {h}
          </li>
        ))
      }
    </ul>

    <div class="flex flex-wrap gap-2 mt-auto pt-4 border-t border-border">
      {project.techStack.map((tech) => <TechTag label={tech} />)}
    </div>
  </div>
</div>
