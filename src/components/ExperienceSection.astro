---
import { useTranslations, type Lang } from '../i18n/utils';
import { getWork } from '../i18n/content/work';
import { getTimeline } from '../i18n/content/experience';
import SectionHeading from './SectionHeading.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const experiences = getWork(lang);
const education = getTimeline(lang);

// Dot colors for the timeline entries
const dotColors = ['bg-accent', 'bg-blue-500', 'bg-purple-500', 'bg-emerald-500', 'bg-pink-500', 'bg-cyan-500', 'bg-yellow-500', 'bg-red-500', 'bg-indigo-500'];
---

<section id="experience" class="py-28 md:py-36">
  <div class="mx-auto max-w-6xl px-6">
    <div data-animate>
      <SectionHeading
        label={lang === 'en' ? 'JOURNEY' : 'PARCOURS'}
        title={lang === 'en' ? 'EXPERIENCE' : 'EXPÉRIENCE'}
      />
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16">
      <!-- Left: Timeline -->
      <div class="relative pl-6 space-y-10 fade-in-stagger">
        <!-- Vertical line -->
        <div class="absolute left-[5px] top-2 bottom-0 w-px bg-border"></div>

        {experiences.map((exp, i) => (
          <div class="relative" data-animate>
            <!-- Colored square dot -->
            <div class={`absolute -left-6 top-1.5 w-[10px] h-[10px] ${dotColors[i % dotColors.length]}`}></div>

            <div class="flex flex-col">
              <span class="text-xs font-mono text-neutral-600 mb-2">{exp.period}</span>
              <h3 class="font-display text-lg md:text-xl font-extrabold text-white uppercase tracking-tight leading-tight">
                {exp.organization}
              </h3>
              <span class="text-sm font-mono text-accent mt-1">{exp.role}</span>
            </div>
          </div>
        ))}

        <!-- Education -->
        {education.map((entry, i) => (
          <div class="relative" data-animate>
            <div class={`absolute -left-6 top-1.5 w-[10px] h-[10px] ${dotColors[(experiences.length + i) % dotColors.length]}`}></div>

            <div class="flex flex-col">
              <span class="text-xs font-mono text-neutral-600 mb-2">{entry.period}</span>
              <h3 class="font-display text-lg md:text-xl font-extrabold text-white uppercase tracking-tight leading-tight">
                {entry.institution}
              </h3>
              <span class="text-sm font-mono text-accent mt-1">{entry.title}</span>
            </div>
          </div>
        ))}
      </div>

      <!-- Right: Decorative area with dotted grid and floating card -->
      <div class="relative hidden lg:flex items-center justify-center min-h-[500px]" data-animate-scale>
        <!-- Dotted grid pattern -->
        <div class="absolute inset-0 opacity-20" style="background-image: radial-gradient(circle, rgba(255,255,255,0.15) 1px, transparent 1px); background-size: 24px 24px;"></div>

        <!-- Floating interactive card -->
        <div class="relative z-10">
          <!-- Glow effect -->
          <div class="absolute -inset-4 bg-accent/[0.08] rounded-2xl blur-2xl"></div>
          <div class="absolute -inset-[1px] rounded-xl bg-gradient-to-b from-accent/40 to-accent/10"></div>

          <div class="relative bg-surface-raised rounded-xl px-8 py-6 flex items-center gap-4 border border-accent/20">
            <!-- Avatar circle -->
            <div class="w-12 h-12 rounded-full bg-accent/20 border border-accent/30 flex items-center justify-center flex-shrink-0">
              <svg class="w-6 h-6 text-accent/70" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
              </svg>
            </div>

            <div>
              <h4 class="font-display text-base font-bold text-white">
                {lang === 'en' ? 'Mohamed Lemine' : 'Mohamed Lemine'}
              </h4>
              <p class="text-xs text-neutral-500 font-mono">
                {lang === 'en' ? 'Click to explore career' : 'Cliquez pour explorer'}
              </p>
            </div>
          </div>

          <!-- Bottom dot indicator -->
          <div class="flex justify-center mt-4">
            <div class="w-2 h-2 rounded-full bg-accent/50"></div>
          </div>
        </div>

        <!-- Decorative corner dots -->
        <div class="absolute top-4 left-4 w-2 h-2 bg-accent/30"></div>
        <div class="absolute top-4 right-4 w-2 h-2 bg-purple-500/30"></div>
        <div class="absolute bottom-4 left-4 w-2 h-2 bg-blue-500/30"></div>
        <div class="absolute bottom-4 right-4 w-2 h-2 bg-pink-500/30"></div>
        <div class="absolute top-1/4 right-8 w-1.5 h-1.5 bg-yellow-500/20"></div>
        <div class="absolute bottom-1/3 left-8 w-1.5 h-1.5 bg-cyan-500/20"></div>
      </div>
    </div>
  </div>
</section>
