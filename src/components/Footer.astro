---
import { useTranslations, type Lang } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const marqueeText = 'DJEIDJAH MOHAMED LEMINE ★ AI ENGINEERING STUDENT ★ ALES, FRANCE ★ ';
---

<footer class="bg-surface border-t border-border overflow-hidden">
  <!-- Scrolling marquee -->
  <div class="py-4">
    <div class="flex overflow-hidden">
      <div class="animate-marquee-slow flex whitespace-nowrap">
        <span class="text-sm font-mono uppercase tracking-[0.15em] text-neutral-600 px-2">{marqueeText}</span>
        <span class="text-sm font-mono uppercase tracking-[0.15em] text-neutral-600 px-2">{marqueeText}</span>
        <span class="text-sm font-mono uppercase tracking-[0.15em] text-neutral-600 px-2">{marqueeText}</span>
        <span class="text-sm font-mono uppercase tracking-[0.15em] text-neutral-600 px-2">{marqueeText}</span>
      </div>
    </div>
  </div>
</footer>
