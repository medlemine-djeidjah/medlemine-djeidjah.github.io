---
import { useTranslations, type Lang, getAlternatePath } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<header id="site-header" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300">
  <nav class="mx-auto max-w-7xl px-6 md:px-10 h-16 flex items-center justify-between">
    <a
      href={lang === 'en' ? '/' : '/fr/'}
      class="font-display text-sm font-bold text-white uppercase tracking-widest hover:text-accent transition-colors"
    >
      PORTFOLIO
    </a>

    <div class="flex items-center gap-4">
      <!-- Resume download -->
      <div class="relative group" id="resume-dropdown">
        <button
          id="resume-btn"
          class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-mono uppercase tracking-[0.15em] text-neutral-500 hover:text-accent border border-border hover:border-accent/30 transition-all"
          aria-expanded="false"
        >
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
          CV
          <svg class="w-3 h-3 transition-transform" id="resume-chevron" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </button>

        <div
          id="resume-menu"
          class="hidden absolute right-0 top-full mt-2 w-40 bg-surface-raised border border-border overflow-hidden z-20 animate-dropdown"
        >
          <a
            href="/CV-en.pdf"
            target="_blank"
            class="flex items-center px-4 py-3 text-xs font-mono text-neutral-400 hover:bg-surface-overlay hover:text-white transition-colors"
          >
            📄 Resume (EN)
          </a>
          <a
            href="/CV-fr.pdf"
            target="_blank"
            class="flex items-center px-4 py-3 text-xs font-mono text-neutral-400 hover:bg-surface-overlay hover:text-white transition-colors border-t border-border"
          >
            📄 CV (FR)
          </a>
        </div>
      </div>

      <!-- Social icons -->
      <div class="flex items-center gap-3">
        <a
          href="https://github.com/medlemine-djeidjah"
          target="_blank"
          rel="noopener noreferrer"
          class="text-neutral-500 hover:text-white transition-colors hover:scale-110 transform duration-200"
          aria-label="GitHub"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
        </a>
        <a
          href="https://www.linkedin.com/in/mohamed-lemine-djeidjah-7774992a2/"
          target="_blank"
          rel="noopener noreferrer"
          class="text-neutral-500 hover:text-[#0A66C2] transition-colors hover:scale-110 transform duration-200"
          aria-label="LinkedIn"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
        </a>
        <a
          href="mailto:djmed3844@gmail.com"
          class="text-neutral-500 hover:text-accent transition-colors hover:scale-110 transform duration-200"
          aria-label="Email"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
          </svg>
        </a>
      </div>

      <!-- Language switcher -->
      <div class="flex items-center text-sm font-medium border border-border rounded overflow-hidden">
        <a href="/" class:list={['px-3 py-1.5 transition-colors', lang === 'en' ? 'bg-accent/15 text-accent' : 'text-neutral-600 hover:text-neutral-400']}>EN</a>
        <a href="/fr/" class:list={['px-3 py-1.5 transition-colors border-l border-border', lang === 'fr' ? 'bg-accent/15 text-accent' : 'text-neutral-600 hover:text-neutral-400']}>FR</a>
      </div>
    </div>
  </nav>
</header>

<script>
  // Resume dropdown toggle
  const resumeBtn = document.getElementById('resume-btn');
  const resumeMenu = document.getElementById('resume-menu');
  const resumeChevron = document.getElementById('resume-chevron');
  const resumeDropdown = document.getElementById('resume-dropdown');

  resumeBtn?.addEventListener('click', (e) => {
    e.stopPropagation();
    const isHidden = resumeMenu?.classList.toggle('hidden');
    resumeBtn.setAttribute('aria-expanded', String(!isHidden));
    resumeChevron?.classList.toggle('rotate-180');
  });

  document.addEventListener('click', (e) => {
    if (!resumeDropdown?.contains(e.target as Node)) {
      resumeMenu?.classList.add('hidden');
      resumeBtn?.setAttribute('aria-expanded', 'false');
      resumeChevron?.classList.remove('rotate-180');
    }
  });

  // Nav background on scroll
  const header = document.getElementById('site-header');
  let lastScroll = 0;

  window.addEventListener('scroll', () => {
    const currentScroll = window.scrollY;

    if (currentScroll > 80) {
      header?.classList.add('nav-scrolled');
    } else {
      header?.classList.remove('nav-scrolled');
    }

    lastScroll = currentScroll;
  }, { passive: true });
</script>
