---
import { useTranslations, type Lang } from '../i18n/utils';
import { getProjects } from '../i18n/content/projects';
import SectionHeading from './SectionHeading.astro';
import ProjectCard from './ProjectCard.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const projects = getProjects(lang);
---

<section id="projects" class="py-28 md:py-36">
  <div class="mx-auto max-w-6xl px-6">
    <div data-animate>
      <SectionHeading
        label={lang === 'en' ? 'WORK' : 'TRAVAUX'}
        title={lang === 'en' ? 'PROJECTS' : 'PROJETS'}
        subtitle={t('section.projects.subtitle')}
      />
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-5" data-animate>
      {
        projects.map((project) => (
          <ProjectCard project={project} />
        ))
      }
    </div>
  </div>
</section>
