---
import { useTranslations, type Lang } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const stats = [
  { value: 4, prefix: '+', suffix: '', label: lang === 'en' ? 'YEARS OF\nEXPERIENCE' : 'ANNÉES\nD\'EXPÉRIENCE' },
  { value: 6, prefix: '+', suffix: '', label: lang === 'en' ? 'PROJECTS\nCOMPLETED' : 'PROJETS\nRÉALISÉS' },
  { value: 95, prefix: '+', suffix: '%', label: lang === 'en' ? 'ML MODEL\nACCURACY' : 'PRÉCISION\nMODÈLE ML' },
];
---

<section id="hero" class="relative min-h-screen flex items-center pt-20 overflow-hidden">
  <div class="relative z-10 mx-auto max-w-6xl px-6 py-16 md:py-24 w-full">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-center">

      <!-- Left: Profile Card -->
      <div class="lg:col-span-5 flex justify-center lg:justify-start" data-animate-left>
        <div class="relative">
          <!-- Decorative dashed arc -->
          <svg class="absolute -top-8 -left-8 w-[calc(100%+64px)] h-[calc(100%+64px)] pointer-events-none" viewBox="0 0 400 500" fill="none">
            <path d="M 50 20 Q -30 250 50 480" stroke="#FF6B00" stroke-width="2" stroke-dasharray="8 8" fill="none" opacity="0.4" />
            <circle cx="50" cy="480" r="5" fill="#FF6B00" opacity="0.6" />
          </svg>

          <!-- Card -->
          <div class="relative bg-surface-raised border border-border rounded-2xl overflow-hidden w-[280px] md:w-[300px]">
            <!-- Photo with orange overlay -->
            <div class="relative h-56 md:h-64 overflow-hidden bg-accent">
              <img
                src="/profile.png"
                alt="Djeidjah Mohamed Lemine"
                class="w-full h-full object-cover object-top mix-blend-multiply"
                loading="eager"
              />
              <div class="absolute inset-0 bg-gradient-to-b from-accent/20 to-accent/60 mix-blend-multiply"></div>
            </div>

            <!-- Card content -->
            <div class="p-6 text-center">
              <h2 class="font-display text-xl font-extrabold text-white tracking-tight">
                {t('hero.name').split(' ').slice(0, 2).join(' ')}
              </h2>

              <!-- Orange dot accent -->
              <div class="flex justify-center mt-3 mb-4">
                <div class="w-5 h-5 rounded-full bg-accent flex items-center justify-center">
                  <svg class="w-2.5 h-2.5 text-black" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>
                  </svg>
                </div>
              </div>

              <p class="text-sm text-neutral-400 leading-relaxed mb-5">
                {lang === 'en'
                  ? 'An AI Engineering Student who builds intelligent systems and innovative solutions.'
                  : 'Un étudiant ingénieur IA qui construit des systèmes intelligents et des solutions innovantes.'
                }
              </p>

              <!-- Social icons -->
              <div class="flex items-center justify-center gap-4">
                <a href="https://github.com/medlemine-djeidjah" target="_blank" rel="noopener noreferrer" class="text-neutral-500 hover:text-white transition-colors" aria-label="GitHub">
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
                </a>
                <a href="https://www.linkedin.com/in/mohamed-lemine-djeidjah-7774992a2/" target="_blank" rel="noopener noreferrer" class="text-neutral-500 hover:text-white transition-colors" aria-label="LinkedIn">
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                </a>
                <a href="mailto:djmed3844@gmail.com" class="text-neutral-500 hover:text-white transition-colors" aria-label="Email">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Right: Title + Tagline + Stats -->
      <div class="lg:col-span-7 text-center lg:text-left" data-animate-right>
        <!-- Large title -->
        <h1 class="font-display font-extrabold tracking-tight leading-[0.95] uppercase">
          <span class="block text-6xl md:text-7xl lg:text-8xl text-white">
            {lang === 'en' ? 'AI' : 'INGÉNIEUR'}
          </span>
          <span class="block text-5xl md:text-6xl lg:text-7xl text-outline mt-1">
            {lang === 'en' ? 'ENGINEER' : 'EN IA'}
          </span>
        </h1>

        <!-- Tagline -->
        <p class="mt-8 text-base md:text-lg text-neutral-500 leading-relaxed max-w-lg mx-auto lg:mx-0">
          {t('hero.tagline')}
        </p>

        <!-- Stats row -->
        <div class="mt-12 flex items-start gap-8 md:gap-12 justify-center lg:justify-start">
          {stats.map((stat) => (
            <div class="text-center lg:text-left">
              <div class="text-4xl md:text-5xl font-display font-extrabold text-white tabular-nums">
                <span data-count={stat.value} data-suffix={stat.suffix} data-prefix={stat.prefix}>0</span>
              </div>
              <p class="text-[10px] md:text-xs text-neutral-600 mt-2 uppercase tracking-[0.15em] font-mono leading-tight whitespace-pre-line">
                {stat.label}
              </p>
            </div>
          ))}
        </div>
      </div>

    </div>
  </div>
</section>
